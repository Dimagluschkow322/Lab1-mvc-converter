<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<VBox alignment="CENTER" spacing="15" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.ConverterController"
      style="-fx-background-color: linear-gradient(to bottom, #a8ede0, #e0f7fa); -fx-padding: 20;">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <!-- Заголовок -->
    <Label text="ФИНАНСОВЫЙ КОНВЕРТЕР"
           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #006064;"/>
    <Label text="Проценты / Коэффициенты / Дроби"
           style="-fx-font-size: 14px; -fx-text-fill: #00838f; -fx-font-style: italic;"/>

    <Separator style="-fx-background-color: #80deea;"/>

    <!-- Выбор типа конвертации -->
    <Label text="Выберите тип конвертации:"
           style="-fx-text-fill: #006064; -fx-font-size: 14px;"/>

    <HBox spacing="20" alignment="CENTER">
        <ComboBox fx:id="fromComboBox" prefWidth="150"
                  style="-fx-background-color: #b2ebf2; -fx-text-fill: #006064; -fx-font-size: 14px; -fx-background-radius: 10px;"/>
        <Label text="→" style="-fx-font-size: 20px; -fx-text-fill: #00838f; -fx-font-weight: bold;"/>
        <ComboBox fx:id="toComboBox" prefWidth="150"
                  style="-fx-background-color: #b2ebf2; -fx-text-fill: #006064; -fx-font-size: 14px; -fx-background-radius: 10px;"/>
    </HBox>

    <!-- Поле ввода -->
    <Label text="Введите значение:"
           style="-fx-text-fill: #006064; -fx-font-size: 14px;"/>
    <TextField fx:id="inputField" promptText="25  или  0.25  или  1/2"
               style="-fx-background-color: #ffffff; -fx-text-fill: #006064; -fx-font-size: 16px; -fx-padding: 10px; -fx-background-radius: 10px; -fx-border-color: #80deea; -fx-border-radius: 10px;"/>

    <!-- Кнопки -->
    <HBox spacing="15" alignment="CENTER">
        <Button text=" КОНВЕРТИРОВАТЬ" onAction="#handleConvert" prefWidth="160"
                style="-fx-background-color: linear-gradient(to right, #26c6da, #00acc1); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 25px; -fx-padding: 8 20;"/>
        <Button text="🗑 ОЧИСТИТЬ" onAction="#handleClear" prefWidth="120"
                style="-fx-background-color: transparent; -fx-text-fill: #00838f; -fx-font-size: 14px; -fx-border-color: #80deea; -fx-border-radius: 25px; -fx-padding: 8 20;"/>
    </HBox>

    <Region prefHeight="10"/>

    <!-- Результат -->
    <Label text="РЕЗУЛЬТАТ:"
           style="-fx-text-fill: #006064; -fx-font-size: 14px; -fx-font-weight: bold;"/>
    <Label fx:id="resultLabel" text="0"
           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #00838f; -fx-effect: dropshadow(gaussian, #80deea, 5, 0.5, 0, 0);"/>

</VBox>
